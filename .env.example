# Template. Copy to .env and fill in. A real API key is REQUIRED to run.

# --- LLM brain: choose ONE provider, then set its key ---
# Options: openrouter | anthropic | openai | ollama
LLM_PROVIDER=openrouter
LLM_MODEL=                       # optional; provider default used if blank (chat)
SCHEDULER_MODEL=openai/gpt-oss-120b   # reliable model for unattended jobs

OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_HOST=http://localhost:11434/v1   # local open-source models, no key needed

# --- AI news sources (optional; comma-separated RSS URLs, has defaults) ---
AI_NEWS_FEEDS=
NEWSLETTER_URLS=https://whatsupinai.beehiiv.com  # up to 3, comma-separated
WORLD_NEWS_FEEDS=https://rss.dw.com/xml/rss-en-top

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Allowlist of numbers that may use Chippy (comma-separated). Scheduled posts go to all.
MY_WHATSAPP_TO=whatsapp:+10000000000,whatsapp:+10000000001

# --- Scheduler ---
DIGEST_HOUR=7
TIMEZONE=Asia/Karachi

# --- Rate limiting ---
DAILY_MESSAGE_LIMIT=20
WARN_AT_REMAINING=6

# --- Storage (conversation memory) ---
DATABASE_URL=sqlite:///personal_agent.db   # or postgresql+psycopg://... on a VPS
